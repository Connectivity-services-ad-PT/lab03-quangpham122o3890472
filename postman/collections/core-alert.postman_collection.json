              "mode": "raw",
              "raw": "{\n  \"sourceService\": \"iot-ingestion\",\n  \"alertType\": \"TEMPERATURE_HIGH\",\n  \"severity\": \"HIGH\",\n  \"message\": \"Temperature exceeded 80°C in Lab A01\"\n}",
              "options": {
